---
import SiteLayout from "../layouts/SiteLayout.astro";
import { productIndex, roleContent } from "../data/siteContent";
const title = "Funções do sistema";
const description = "Índice completo das funções do VTUR: vendas, importações, CRM, orçamentos, relatórios, financeiro, operação, gestão e master.";
---
<SiteLayout title={title} description={description}>
  <section class="page-hero"><div class="shell hero-layout"><div><span class="eyebrow">Índice completo</span><h1 class="hero-title">Tudo que o VTUR entrega, separado por área de uso.</h1><p class="hero-copy">Esta pagina organiza o sistema como ele e vendido e operado: primeiro pelas grandes áreas, depois pelos perfis que acessam cada camada.</p><div class="hero-actions"><a class="button" href="#vendas">Comecar por vendas</a><a class="button-secondary" href="#perfis">Ver por perfil</a></div></div><aside class="hero-panel compact-panel"><strong>Áreas cobertas</strong><ul class="trust-list two-col-list"><li>Vendas CVC, Cruzeiro e Rextur</li><li>CRM e últimas compras</li><li>Orçamentos e roteiros</li><li>Relatórios completos</li><li>Financeiro e comissões</li><li>Master multiempresa</li></ul></aside></div></section>
  <section class="section tinted-section"><div class="shell product-index-stack">{productIndex.map((section) => <article class="product-section" id={section.id}><div class="product-section-head"><span>{section.number}</span><div><h2>{section.title}</h2><p>{section.summary}</p></div></div><div class="module-grid three-col">{section.features.map((feature) => <article class="module-item"><strong>{feature.name}</strong><p>{feature.description}</p></article>)}</div></article>)}</div></section>
  <section class="section" id="perfis"><div class="shell"><div class="section-header"><p class="section-kicker">Perfis de acesso</p><h2 class="section-title">O mesmo produto, quatro experiências diferentes.</h2><p class="section-intro">A plataforma respeita escopo e permissão. Isso evita excesso de menu, protege funções sensiveis e deixa cada usuário focado no que precisa operar.</p></div><div class="module-groups">{roleContent.map((role) => <article class="role-section" id={role.id === 'financeiro' ? 'financeiro-perfil' : role.id}><div class="role-topline"><div><span class="role-badge">{role.badge}</span><h2 class="role-label">{role.label}</h2><p class="role-summary">{role.summary}</p></div><a class="button-secondary" href="/contato">Solicitar demonstração</a></div>{role.inherit && <p class="inherit-note">{role.inherit}</p>}<ul class="outcomes-list">{role.outcomes.map((item) => <li>{item}</li>)}</ul><div class="module-groups nested-groups">{role.groups.map((group) => <section class="module-group"><h3 class="module-group-title">{group.title}</h3><p class="module-group-copy">{group.description}</p><div class="module-grid">{group.modules.map((module) => <article class="module-item"><strong>{module.name}</strong><p>{module.description}</p></article>)}</div></section>)}</div></article>)}</div></div></section>
  <section class="cta-section"><div class="shell"><div class="cta-panel"><h2>Uma demonstração forte deve seguir este índice.</h2><p>Comece pela importação de vendas, avance para CRM e relatórios, e feche mostrando governança, financeiro e master multiempresa.</p><div class="cta-actions"><a class="button" href="/contato">Planejar demonstração</a><a class="button-secondary" href="/planos">Ver planos</a></div></div></div></section>
</SiteLayout>
