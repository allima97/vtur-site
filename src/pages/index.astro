---
import SiteLayout from "../layouts/SiteLayout.astro";
import { faqs, homepagePillars, implementationSteps, productIndex, productMosaic, roleHighlights } from "../data/siteContent";
const title = "CRM operacional para turismo";
const description = "VTUR organiza CRM, vendas, importação CVC, Rextur, cruzeiros, relatórios, financeiro, viagens e governança multiempresa.";
---
<SiteLayout title={title} description={description}>
  <section class="page-hero"><div class="shell hero-layout hero-layout-wide"><div><span class="eyebrow">Sistema em produção para turismo</span><h1 class="hero-title">Venda, operação e reservas em uma rotina mais simples.</h1><p class="hero-copy">O VTUR conecta CRM, importação de vendas, orçamentos, viagens, financeiro, comissões, relatórios e governança multiempresa em uma experiência visual limpa e orientada a rotina real da agência.</p><div class="hero-actions"><a class="button" href="/produto">Explorar funções</a><a class="button-secondary" href="/contato">Solicitar demonstração</a></div></div><aside class="product-screen hero-screen product-carousel system-carousel" aria-label="Telas do sistema VTUR">
  <div class="screen-topbar"><span></span><span></span><span></span></div>
  <div class="carousel-track">
    <section class="carousel-slide system-slide">
      <div class="screen-header-row"><div><small>Dashboard gestor</small><strong>Painel de vendas da equipe</strong></div><span class="status-pill">Maio 2026</span></div>
      <div class="system-kpis">
        <div class="system-kpi accent-orange"><i>↗</i><span>Vendas no período</span><strong>R$ 209.016,28</strong><small>Lucro: R$ 197.704,32</small></div>
        <div class="system-kpi accent-green"><i>Q</i><span>Qtd. vendas</span><strong>18</strong><small>Ticket: R$ 11.612,02</small></div>
        <div class="system-kpi accent-indigo"><i>◎</i><span>Meta do mês</span><strong>R$ 390.000,00</strong><em><b style="width:54%"></b></em><small>53.6% atingido</small></div>
        <div class="system-kpi accent-slate"><i>▣</i><span>Dias no mês</span><strong>25d</strong><small>Meta/dia: R$ 7.239,35</small></div>
        <div class="system-kpi accent-yellow"><i>◇</i><span>Seguro viagem</span><strong>R$ 6.460,66</strong><em><b style="width:88%"></b></em><small>165.7% meta</small></div>
      </div>
    </section>
    <section class="carousel-slide system-slide">
      <div class="screen-header-row"><div><small>Relatórios</small><strong>Destinos e vendas por produto</strong></div><span class="status-pill">Equipe</span></div>
      <div class="system-report-grid">
        <article class="system-panel"><div class="system-panel-head"><strong>Top destinos</strong><small>Mais vendidos do período</small></div><div class="system-ranking"><div><b>1</b><span><strong>Helsinque</strong><small>6 vendas</small></span><em>R$ 59.277,20</em></div><div><b>2</b><span><strong>Ushuaia</strong><small>5 vendas</small></span><em>R$ 39.666,66</em></div><div><b>3</b><span><strong>Santos</strong><small>3 vendas</small></span><em>R$ 22.692,59</em></div><div><b>4</b><span><strong>Buenos Aires</strong><small>7 vendas</small></span><em>R$ 17.840,86</em></div></div></article>
        <article class="system-panel"><div class="system-panel-head"><strong>Vendas por produto</strong><small>Distribuição de receita por produto</small></div><div class="system-bars"><span style="--h:132px;--c:#fb923c" data-label="Aéreo + Hotel"></span><span style="--h:82px;--c:#fdba74" data-label="Produto"></span><span style="--h:54px;--c:#fed7aa" data-label="Passagem"></span><span style="--h:42px;--c:#ffedd5" data-label="Fretamento"></span><span style="--h:28px;--c:#fff7ed" data-label="Resort"></span><span style="--h:24px;--c:#cbd5e1" data-label="Serviços"></span></div></article>
      </div>
    </section>
    <section class="carousel-slide system-slide">
      <div class="screen-header-row"><div><small>Home do vendedor</small><strong>Viagens, atividades e aniversariantes</strong></div><span class="status-pill">Hoje</span></div>
      <div class="system-home-grid">
        <article class="system-panel system-list-card"><div class="system-panel-head with-icon"><i>✈</i><div><strong>Próximas viagens</strong><small>Saídas nos próximos dias</small></div></div><div class="travel-item"><span>◎</span><div><strong>inter plus 150k com assistcard...</strong><small>Cayo Henrique · 06/05/2026</small></div><b>Em viagem</b></div><div class="travel-item"><span>◎</span><div><strong>soft win hotel sao luis</strong><small>Regina Maria · 07/05/2026</small></div><b>Confirmado</b></div><div class="travel-item active"><span>◎</span><div><strong>transporte compartilhado</strong><small>Regina Maria · 07/05/2026</small></div><b>Confirmado</b></div></article>
        <article class="system-panel system-list-card"><div class="system-panel-head with-icon"><i>◷</i><div><strong>Atividades recentes</strong><small>Últimas movimentações</small></div></div><div class="activity-row"><span>◷</span><div><strong>Follow-up Olímpia</strong><small>Simone Helena Cunha</small></div><b>Há 2 dias</b></div><div class="activity-row"><span>▤</span><div><strong>Orçamento enviado</strong><small>Cliente</small></div><b>27/04</b></div><div class="activity-row"><span>✈</span><div><strong>Viagem confirmada</strong><small>Regina Maria Lucas</small></div><b>Agora</b></div></article>
        <article class="system-panel system-list-card"><div class="system-panel-head with-icon"><i>□</i><div><strong>Aniversariantes</strong><small>Próximos aniversários</small></div></div><div class="birthday-row"><span>MI</span><div><strong>Maria Ines Pedroso</strong><small>66 anos · Amanhã</small></div></div><div class="birthday-row"><span>MO</span><div><strong>Mauro Ohzeki</strong><small>53 anos · 09/05/1972</small></div></div><div class="birthday-row"><span>RS</span><div><strong>Regina Setsuko</strong><small>67 anos · 11/05/1958</small></div></div></article>
      </div>
    </section>
    <section class="carousel-slide system-slide">
      <div class="screen-header-row"><div><small>Financeiro</small><strong>Conciliação e importação de recebíveis</strong></div><span class="status-pill">Rextur + CVC</span></div>
      <div class="system-kpis system-kpis-four"><div class="system-kpi accent-indigo"><i>✓</i><span>Conciliados</span><strong>48</strong></div><div class="system-kpi accent-orange"><i>!</i><span>Pendentes</span><strong>6</strong></div><div class="system-kpi accent-slate"><i>R</i><span>Baixa RAC</span><strong>2</strong></div><div class="system-kpi accent-green"><i>$</i><span>Taxas lidas</span><strong>R$ 12.910</strong></div></div>
      <div class="finance-preview system-table"><div class="finance-line head"><span>Documento</span><span>Status</span><span>Diferença</span></div><div class="finance-line"><strong>BYARDM</strong><span class="mini-badge ok">OK</span><small>R$ 0,00</small></div><div class="finance-line"><strong>BXR9TU</strong><span class="mini-badge warn">Taxas</span><small>R$ 196,97</small></div><div class="finance-line"><strong>FTDYHW</strong><span class="mini-badge ok">OK</span><small>R$ 0,00</small></div></div>
      <div class="screen-list compact"><div><span class="dot"></span><strong>RC somado às taxas</strong><small>Tax. Emb. + RC no total importado</small></div><div><span class="dot blue"></span><strong>Ranking resolvido</strong><small>Vendedor e produto por recibo</small></div></div>
    </section>
  </div>
  <div class="carousel-dots" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
</aside></div></section>
  <section class="section compact-section"><div class="shell proof-strip"><span>Importação CVC</span><span>Rextur com RC</span><span>Cruzeiros</span><span>Ranking</span><span>Conciliação</span><span>Master multiempresa</span></div></section>
  <section class="section"><div class="shell"><div class="section-header split-header"><div><p class="section-kicker">Por que o VTUR é diferente</p><h2 class="section-title">Ele foi feito para a rotina de turismo, nao para um CRM genérico.</h2></div><p class="section-intro">Cada módulo conversa com uma etapa da jornada: cliente, proposta, venda, reserva, viagem, financeiro, comissão e relatório.</p></div><div class="pillars-grid">{homepagePillars.map((item) => <article class="card feature-card"><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell"><div class="section-header"><p class="section-kicker">Índice do produto</p><h2 class="section-title">O poder do sistema organizado por área.</h2><p class="section-intro">Esta e a leitura comercial completa: o que o sistema faz, em qual contexto e qual problema resolve.</p></div><div class="index-grid">{productIndex.map((section) => <a class="index-card" href={'/produto#' + section.id}><span>{section.number}</span><strong>{section.title}</strong><p>{section.summary}</p></a>)}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Arquitetura da plataforma</p><h2 class="section-title">Um sistema único para comercial, operação, financeiro e gestão.</h2></div><div class="overview-grid">{productMosaic.map((item) => <article class="overview-card"><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell"><div class="section-header"><p class="section-kicker">Perfis</p><h2 class="section-title">Cada usuário ve o que precisa operar.</h2></div><div class="role-bands">{roleHighlights.map((item, index) => { const ids = ["vendedor", "gestor", "master"]; return <article class="role-band" data-role={ids[index]}><strong>{item.title}</strong><p>{item.description}</p><a class="role-link" href={'/produto#' + ids[index]}>Ver perfil</a></article>; })}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Implantacao</p><h2 class="section-title">Go-live com metodo, parametrização e validação.</h2></div><div class="steps-grid">{implementationSteps.map((item, index) => <article class="step-card"><span>{'0' + (index + 1)}</span><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Perguntas frequentes</p><h2 class="section-title">Respostas diretas para uma demonstração objetiva.</h2></div><div class="faq-stack">{faqs.map((item) => <details class="faq-item"><summary>{item.question}</summary><p>{item.answer}</p></details>)}</div></div></section>
  <section class="cta-section"><div class="shell"><div class="cta-panel"><h2>Mostre o VTUR pelo que ele resolve: venda, operação, financeiro e governança.</h2><p>O site agora apresenta o sistema como plataforma completa, com funções organizadas por índice e discurso coerente com a identidade visual atual.</p><div class="cta-actions"><a class="button" href="/produto">Ver índice completo</a><a class="button-secondary" href="/contato">Agendar demonstração</a></div></div></div></section>
</SiteLayout>
