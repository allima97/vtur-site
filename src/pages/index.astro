---
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  faqs,
  homepagePillars,
  implementationSteps,
  pricingPlans,
  productMosaic,
  roleContent,
  roleHighlights,
} from "../data/siteContent";

const title = "CRM completo para turismo e viagens";
const description =
  "O vtur conecta CRM, vendas, orcamentos, operacao, atendimento, gestao e governanca multiempresa em uma unica plataforma.";
---

<SiteLayout title={title} description={description}>
  <section class="page-hero">
    <div class="shell hero-layout">
      <div>
        <span class="eyebrow">CRM completo para turismo e viagens</span>
        <h1 class="hero-title">Mais do que vendas: relacionamento, operacao e gestao em uma unica plataforma.</h1>
        <p class="hero-copy">
          O vtur foi desenhado para equipes comerciais, liderancas e operacoes multiempresa que
          precisam acompanhar clientes, propostas, vendas, viagens, atendimento, performance e
          governanca sem fragmentar a rotina em varias ferramentas.
        </p>
        <div class="hero-actions">
          <a class="button" href="/contato">Solicitar demonstracao</a>
          <a class="button-secondary" href="/produto">Ver modulos por perfil</a>
        </div>
      </div>

      <aside class="hero-panel">
        <div class="stat-grid">
          <article class="stat-card">
            <strong>Frente comercial</strong>
            <span>Clientes, orcamentos, vendas, contratos, consultoria e follow-up integrados.</span>
          </article>
          <article class="stat-card">
            <strong>Operacao</strong>
            <span>Viagens, documentos, SAC, campanhas, agenda, tarefas e rotina de atendimento.</span>
          </article>
          <article class="stat-card">
            <strong>Gestao</strong>
            <span>Metas, escalas, equipe, comissionamento, regras comerciais e relatorios.</span>
          </article>
          <article class="stat-card">
            <strong>Governanca</strong>
            <span>Permissoes por perfil, visao por empresa e camada master para grupos e redes.</span>
          </article>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">Posicionamento</p>
        <h2 class="section-title">Como o vtur deve ser percebido no mercado</h2>
        <p class="section-intro">
          O site institucional passa a posicionar o produto como um CRM especializado no turismo,
          com profundidade operacional, leitura gerencial e governanca corporativa. Essa e a mesma
          logica usada por grandes empresas SaaS: valor primeiro, modulos depois.
        </p>
      </div>

      <div class="pillars-grid">
        {homepagePillars.map((item) => (
          <article class="card">
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">Arquitetura do produto</p>
        <h2 class="section-title">Uma plataforma unica para a rotina completa da operacao</h2>
        <p class="section-intro">
          Em vez de apresentar o sistema como um simples gerenciador de vendas, o vtur organiza o
          discurso em blocos que fazem sentido para o negocio: CRM, comercial, operacao, financeiro,
          performance e governanca.
        </p>
      </div>

      <div class="overview-grid">
        {productMosaic.map((item) => (
          <article class="overview-card">
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">Perfis do sistema</p>
        <h2 class="section-title">O produto se adapta ao papel de cada usuario</h2>
        <p class="section-intro">
          O site passa a explicar o sistema por permissao e responsabilidade operacional. Isso reduz
          ruido comercial, facilita a venda consultiva e aumenta a percepcao de maturidade do produto.
        </p>
      </div>

      <div class="role-bands">
        {roleHighlights.map((item, index) => {
          const roleId = roleContent[index]?.id ?? "vendedor";
          return (
            <article class="role-band" data-role={roleId}>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
              <a class="role-link" href={`/produto#${roleId}`}>Ver modulos</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">Implantacao</p>
        <h2 class="section-title">Confianca tambem se constroi mostrando metodo</h2>
        <p class="section-intro">
          Grandes empresas de software nao vendem apenas telas. Elas explicam processo, previsibilidade
          e governanca. O vtur precisa fazer o mesmo para transmitir integridade e preparo operacional.
        </p>
      </div>

      <div class="steps-grid">
        {implementationSteps.map((item, index) => (
          <article class="step-card">
            <span>0{index + 1}</span>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">Planos</p>
        <h2 class="section-title">Comercialize por camada de maturidade, nao por lista solta de features</h2>
        <p class="section-intro">
          A pagina de planos foi estruturada para acomodar a tabela comercial definitiva depois, sem
          inventar precos agora. O desenho ja segue a logica do produto: Comercial, Gestao e Master.
        </p>
      </div>

      <div class="plans-grid">
        {pricingPlans.map((plan) => (
          <article class:list={["plan-card", { highlight: plan.highlight }]}>
            <span class="plan-badge">{plan.name}</span>
            <strong>{plan.name}</strong>
            <p class="plan-audience">{plan.audience}</p>
            <div class="plan-price">
              {plan.price}
              <small>{plan.description}</small>
            </div>
            <ul class="plan-features">
              {plan.features.map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="plan-actions">
              <a class={plan.highlight ? "button-secondary" : "button"} href="/planos">Explorar plano</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-header">
        <p class="section-kicker">FAQ estrategico</p>
        <h2 class="section-title">As respostas que fortalecem confianca logo na apresentacao</h2>
      </div>

      <div class="faq-stack">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="shell">
      <div class="cta-panel">
        <h2>O vtur deve vender clareza, profundidade e governanca.</h2>
        <p>
          A base institucional ja nasce alinhada com esse posicionamento: um CRM completo para
          turismo e viagens, com paginas de produto, perfis, planos, institucional e contato prontas
          para evoluir comercialmente.
        </p>
        <div class="cta-actions">
          <a class="button" href="/produto">Mapeamento completo dos modulos</a>
          <a class="button-secondary" href="/contato">Planejar demonstracao comercial</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
