---
import SiteLayout from "../layouts/SiteLayout.astro";
import { faqs, homepagePillars, implementationSteps, productIndex, productMosaic, roleHighlights } from "../data/siteContent";
const title = "CRM operacional para turismo";
const description = "VTUR organiza CRM, vendas, importação CVC, Rextur, cruzeiros, relatórios, financeiro, viagens e governança multiempresa.";
---
<SiteLayout title={title} description={description}>
  <section class="page-hero"><div class="shell hero-layout hero-layout-wide"><div><span class="eyebrow">Sistema em produção para turismo</span><h1 class="hero-title">Venda, operação e reservas em uma rotina mais simples.</h1><p class="hero-copy">O VTUR conecta CRM, importação de vendas, orçamentos, viagens, financeiro, comissões, relatórios e governança multiempresa em uma experiência visual limpa e orientada a rotina real da agência.</p><div class="hero-actions"><a class="button" href="/produto">Explorar funções</a><a class="button-secondary" href="/contato">Solicitar demonstração</a></div></div><aside class="product-screen hero-screen clean-carousel" aria-label="Resumo visual limpo do sistema VTUR">
  <div class="clean-track">
    <section class="clean-slide">
      <div class="clean-screen-head"><div><small>Dashboard gestor</small><strong>Vendas no período</strong></div><span>Maio 2026</span></div>
      <div class="clean-kpis"><div><i>↗</i><small>Vendas no período</small><strong>R$ 209.016</strong><em>Lucro: R$ 197.704</em></div><div><i>◎</i><small>Meta do mês</small><strong>53,6%</strong><b><span style="width:54%"></span></b></div><div><i>◇</i><small>Seguro viagem</small><strong>R$ 6.460</strong><b><span style="width:86%"></span></b></div></div>
      <div class="clean-two"><article><header><strong>Top destinos</strong><small>Mais vendidos do período</small></header><div class="clean-rank"><p><b>1</b><span>Roma</span><em>R$ 44.396</em></p><p><b>2</b><span>Rio Quente</span><em>R$ 6.156</em></p><p><b>3</b><span>Barcelona</span><em>R$ 3.896</em></p></div></article><article><header><strong>Vendas por produto</strong><small>Distribuição de receita</small></header><div class="clean-bars"><span style="--h:86%;--c:#fb923c"></span><span style="--h:38%;--c:#fdba74"></span><span style="--h:24%;--c:#fed7aa"></span><span style="--h:16%;--c:#ffedd5"></span></div></article></div>
    </section>
    <section class="clean-slide">
      <div class="clean-screen-head"><div><small>Operação</small><strong>Viagens e atividades</strong></div><span>Hoje</span></div>
      <div class="clean-three"><article><header><strong>Próximas viagens</strong><small>Saídas nos próximos dias</small></header><div class="clean-trip"><i>◎</i><div><strong>Inter plus 150k com assistcard</strong><small>Cayo Henrique · 06/05/2026</small></div><em>Em viagem</em></div><div class="clean-trip"><i>◎</i><div><strong>Soft win hotel São Luís</strong><small>Regina Maria · 07/05/2026</small></div><em>Confirmado</em></div></article><article><header><strong>Atividades recentes</strong><small>Últimas movimentações</small></header><div class="clean-activity"><i>◷</i><div><strong>Follow-up Olímpia</strong><small>Simone Helena</small></div><em>2 dias</em></div><div class="clean-activity"><i>▤</i><div><strong>Orçamento enviado</strong><small>Cliente</small></div><em>17h</em></div><div class="clean-activity"><i>✈</i><div><strong>Viagem confirmada</strong><small>Regina Lucas</small></div><em>Agora</em></div></article><article><header><strong>Aniversariantes</strong><small>Próximos contatos</small></header><div class="clean-person"><b>MI</b><div><strong>Maria Ines Pedroso</strong><small>66 anos · Amanhã</small></div></div><div class="clean-person"><b>MO</b><div><strong>Mauro Ohzeki</strong><small>53 anos · 09/05</small></div></div><div class="clean-person"><b>RS</b><div><strong>Regina Setsuko</strong><small>67 anos · 11/05</small></div></div></article></div>
    </section>
    <section class="clean-slide">
      <div class="clean-screen-head"><div><small>Financeiro</small><strong>Conciliação e importação</strong></div><span>Rextur + CVC</span></div>
      <div class="clean-kpis"><div><i>✓</i><small>Conciliados</small><strong>48</strong></div><div><i>!</i><small>Pendentes</small><strong>6</strong></div><div><i>$</i><small>Taxas lidas</small><strong>R$ 12.910</strong></div></div>
      <article class="clean-table"><header><strong>Recibos importados</strong><small>Conferência de taxas e RC</small></header><div><span>Documento</span><span>Status</span><span>Diferença</span></div><p><strong>BYARDM</strong><b>OK</b><em>R$ 0,00</em></p><p><strong>BXR9TU</strong><b class="warn">Taxas</b><em>R$ 196,97</em></p><p><strong>FTDYHW</strong><b>OK</b><em>R$ 0,00</em></p></article>
    </section>
  </div>
  <div class="clean-dots" aria-hidden="true"><span></span><span></span><span></span></div>
</aside></div></section>
  <section class="section compact-section"><div class="shell proof-strip"><span>Importação CVC</span><span>Rextur com RC</span><span>Cruzeiros</span><span>Ranking</span><span>Conciliação</span><span>Master multiempresa</span></div></section>
  <section class="section"><div class="shell"><div class="section-header split-header"><div><p class="section-kicker">Por que o VTUR é diferente</p><h2 class="section-title">Ele foi feito para a rotina de turismo, nao para um CRM genérico.</h2></div><p class="section-intro">Cada módulo conversa com uma etapa da jornada: cliente, proposta, venda, reserva, viagem, financeiro, comissão e relatório.</p></div><div class="pillars-grid">{homepagePillars.map((item) => <article class="card feature-card"><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell"><div class="section-header"><p class="section-kicker">Índice do produto</p><h2 class="section-title">O poder do sistema organizado por área.</h2><p class="section-intro">Esta e a leitura comercial completa: o que o sistema faz, em qual contexto e qual problema resolve.</p></div><div class="index-grid">{productIndex.map((section) => <a class="index-card" href={'/produto#' + section.id}><span>{section.number}</span><strong>{section.title}</strong><p>{section.summary}</p></a>)}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Arquitetura da plataforma</p><h2 class="section-title">Um sistema único para comercial, operação, financeiro e gestão.</h2></div><div class="overview-grid">{productMosaic.map((item) => <article class="overview-card"><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell"><div class="section-header"><p class="section-kicker">Perfis</p><h2 class="section-title">Cada usuário ve o que precisa operar.</h2></div><div class="role-bands">{roleHighlights.map((item, index) => { const ids = ["vendedor", "gestor", "master"]; return <article class="role-band" data-role={ids[index]}><strong>{item.title}</strong><p>{item.description}</p><a class="role-link" href={'/produto#' + ids[index]}>Ver perfil</a></article>; })}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Implantacao</p><h2 class="section-title">Go-live com metodo, parametrização e validação.</h2></div><div class="steps-grid">{implementationSteps.map((item, index) => <article class="step-card"><span>{'0' + (index + 1)}</span><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Perguntas frequentes</p><h2 class="section-title">Respostas diretas para uma demonstração objetiva.</h2></div><div class="faq-stack">{faqs.map((item) => <details class="faq-item"><summary>{item.question}</summary><p>{item.answer}</p></details>)}</div></div></section>
  <section class="cta-section"><div class="shell"><div class="cta-panel"><h2>Mostre o VTUR pelo que ele resolve: venda, operação, financeiro e governança.</h2><p>O site agora apresenta o sistema como plataforma completa, com funções organizadas por índice e discurso coerente com a identidade visual atual.</p><div class="cta-actions"><a class="button" href="/produto">Ver índice completo</a><a class="button-secondary" href="/contato">Agendar demonstração</a></div></div></div></section>
</SiteLayout>
