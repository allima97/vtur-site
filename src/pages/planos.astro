---
import SiteLayout from "../layouts/SiteLayout.astro";
import { pricingPlans } from "../data/siteContent";
const title = "Planos";
const description = "Planos do VTUR organizados por maturidade: Comercial, Gestão e Master.";
---
<SiteLayout title={title} description={description}>
  <section class="page-hero"><div class="shell hero-layout"><div><span class="eyebrow">Estrutura comercial</span><h1 class="hero-title">Contrate pela maturidade da operação, não por uma lista solta de telas.</h1><p class="hero-copy">O VTUR pode entrar pela camada comercial e evoluir para gestão, financeiro e master multiempresa conforme a operação cresce.</p><div class="hero-actions"><a class="button" href="/contato">Solicitar proposta</a><a class="button-secondary" href="/produto">Comparar funções</a></div></div><aside class="hero-panel compact-panel"><strong>Modelo recomendado</strong><ul class="trust-list"><li>Comercial para organizar venda e carteira.</li><li>Gestão para liderar equipe e controlar parâmetros.</li><li>Master para consolidar empresas e governança.</li></ul></aside></div></section>
  <section class="section"><div class="shell"><div class="plans-grid">{pricingPlans.map((plan) => <article class:list={["plan-card", { highlight: plan.highlight }]}><span class="plan-badge">{plan.name}</span><strong>{plan.name}</strong><p class="plan-audience">{plan.audience}</p><div class="plan-price">{plan.price}<small>{plan.description}</small></div><ul class="plan-features">{plan.features.map((feature) => <li>{feature}</li>)}</ul><div class="plan-actions"><a class={plan.highlight ? "button-secondary" : "button"} href="/contato">Solicitar proposta</a></div></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell content-layout"><div class="content-copy"><div class="section-header"><p class="section-kicker">Como escolher</p><h2 class="section-title">O escopo certo depende do que a loja precisa controlar.</h2></div><h3>Quando escolher Comercial</h3><p>Quando a prioridade e estruturar CRM, importar vendas, acompanhar propostas, viagens e relatórios individuais.</p><h3>Quando escolher Gestão</h3><p>Quando existe equipe, meta, ranking, cadastros, escala, conciliação ou necessidade de padronizar a loja.</p><h3>Quando escolher Master</h3><p>Quando ha mais de uma empresa, unidade ou equipe no escopo e a operação precisa de governança consolidada.</p></div><aside class="content-panel"><strong>Itens para proposta</strong><ul class="trust-list"><li>Número de usuários ativos.</li><li>Quantidade de empresas ou lojas.</li><li>Perfis necessários.</li><li>Importações de venda usadas no dia a dia.</li><li>Necessidade de migração e treinamento.</li></ul></aside></div></section>
</SiteLayout>
