---
import SiteLayout from "../layouts/SiteLayout.astro";
import { implementationSteps, institutionalPrinciples } from "../data/siteContent";
const title = "Institucional";
const description = "Conheça o posicionamento do VTUR: especialização em turismo, operação real e governança por perfil.";
---
<SiteLayout title={title} description={description}>
  <section class="page-hero"><div class="shell hero-layout"><div><span class="eyebrow">Institucional</span><h1 class="hero-title">Tecnologia para agências que precisam controlar a jornada completa da venda.</h1><p class="hero-copy">O VTUR nasceu para organizar a rotina de turismo: cliente, proposta, contrato, reserva, viagem, financeiro, relatório e governança.</p><div class="hero-actions"><a class="button" href="/produto">Conhecer funções</a><a class="button-secondary" href="/contato">Falar sobre implantação</a></div></div><aside class="hero-panel compact-panel"><strong>Princípios do produto</strong><ul class="trust-list"><li>Especialização no mercado de turismo.</li><li>Fluxos reais antes de modismos.</li><li>Segurança por perfil e empresa.</li></ul></aside></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Posicionamento</p><h2 class="section-title">O VTUR organiza operações que ja cresceram alem da planilha.</h2></div><div class="value-grid">{institutionalPrinciples.map((item) => <article class="card"><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
  <section class="section tinted-section"><div class="shell content-layout"><div class="content-copy"><div class="section-header"><p class="section-kicker">Narrativa</p><h2 class="section-title">Um sistema com profundidade operacional e visual atual.</h2></div><h3>Feito para turismo</h3><p>O produto trata recibos, reservas, passageiros, taxas, vouchers, viagens, SAC e comissões como entidades centrais.</p><h3>Feito para equipe</h3><p>Cada perfil acessa uma experiência própria. O vendedor vende; o gestor acompanha; o financeiro controla; o master governa.</p><h3>Feito para crescer</h3><p>A estrutura multiempresa permite consolidar lojas, equipes, usuários e permissões sem perder rastreabilidade.</p></div><aside class="content-panel"><strong>O que a marca comunica</strong><ul class="trust-list"><li>Clareza visual e densidade de informação.</li><li>Processos auditáveis e menos retrabalho.</li><li>Módulos integrados em vez de ferramentas isoladas.</li><li>Evolução contínua conforme a operação amadurece.</li></ul></aside></div></section>
  <section class="section"><div class="shell"><div class="section-header"><p class="section-kicker">Implantação</p><h2 class="section-title">Método para entrar em produção com segurança.</h2></div><div class="steps-grid">{implementationSteps.map((item, index) => <article class="step-card"><span>{'0' + (index + 1)}</span><strong>{item.title}</strong><p>{item.description}</p></article>)}</div></div></section>
</SiteLayout>
