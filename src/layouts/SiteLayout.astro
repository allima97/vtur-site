---
import "../styles/site.css";
import { navigation } from "../data/siteContent";
type Props = { title: string; description: string };
const { title, description } = Astro.props as Props;
const pathname = Astro.url.pathname;
const pageTitle = title + " | VTUR";
const isActive = (href: string) => href === "/" ? pathname === "/" : pathname.startsWith(href);
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1e1b4b" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/brand/vtur-symbol.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-backdrop" aria-hidden="true"><div class="site-grid"></div></div>
    <header class="site-header">
      <div class="shell header-bar">
        <a class="brand" href="/"><img src="/brand/vtur-symbol.png?v=7" alt="Símbolo do VTUR" /><div class="brand-copy"><strong>VTUR</strong><span>CRM para Franquias CVC</span></div></a>
        <nav class="top-nav" aria-label="Principal">{navigation.map((item) => <a class={isActive(item.href) ? "active" : undefined} href={item.href}>{item.label}</a>)}</nav>
        <a class="header-cta" href="/contato">Agendar demonstração</a>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer"><div class="shell footer-grid">
      <div class="footer-brand"><img src="/brand/vtur-symbol.png?v=7" alt="Símbolo do VTUR" /><div><strong>VTUR</strong><p>CRM operacional para agências, franquias e equipes de turismo que precisam vender, operar e gerir com rastreabilidade.</p></div></div>
      <div class="footer-links"><strong>Produto</strong><a href="/produto#vendas">Vendas e importação</a><a href="/produto#relatorios">Relatórios</a><a href="/produto#financeiro">Financeiro</a><a href="/produto#master-admin">Master e admin</a></div>
      <div class="footer-links"><strong>Perfis</strong><a href="/produto#vendedor">Vendedor</a><a href="/produto#gestor">Gestor</a><a href="/produto#financeiro-perfil">Financeiro</a><a href="/produto#master">Master</a></div>
    </div></footer>
  </body>
</html>
